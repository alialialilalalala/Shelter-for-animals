<Window x:Class="AnimalShelterAI.AdoptionApplicationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Заявка на усыновление"
        Height="650" Width="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA"
                Icon="C:\Users\alialialilalala\Pictures\Screenshots\shelter.png"
>

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Opacity="0.12" Color="#000000"/>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource SuccessGradient}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🏠" FontSize="32" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock Text="Новая заявка на усыновление" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Заполните форму, чтобы забрать питомца домой" FontSize="12" Foreground="#B0BEC5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Информация о животном -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="🐾 Информация о животном" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="80" Height="80" CornerRadius="10" Background="#F1F3F5" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,15,0">
                                <Grid>
                                    <Image x:Name="imgAnimalPhoto" Stretch="UniformToFill" Width="80" Height="80"/>
                                    <TextBlock x:Name="txtNoPhoto" Text="🐾" FontSize="30" Foreground="#BDC3C7" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible"/>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="txtAnimalName" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                                <TextBlock x:Name="txtAnimalDetails" FontSize="13" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                                <Border x:Name="borderStatus" CornerRadius="6" Padding="8,4" Margin="0,8,0,0" HorizontalAlignment="Left">
                                    <TextBlock x:Name="txtStatus" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Информация о заявителе -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="👤 Информация о вас" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Ваше имя" Foreground="#667EEA" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtFullName" Height="42" Padding="12,10" FontSize="14" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" IsReadOnly="True"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Email" Foreground="#667EEA" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtEmail" Height="42" Padding="12,10" FontSize="14" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" IsReadOnly="True"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Телефон" Foreground="#667EEA" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtPhone" Height="42" Padding="12,10" FontSize="14" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Адрес проживания" Foreground="#667EEA" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtAddress" Height="42" Padding="12,10" FontSize="14" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Условия содержания -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="🏡 Условия содержания" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                        <TextBlock Text="Где будет жить животное?" Foreground="#667EEA" FontSize="13" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbLivingCondition" Height="42" FontSize="14" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,0,15">
                            <ComboBoxItem Content="Квартира" IsSelected="True"/>
                            <ComboBoxItem Content="Частный дом"/>
                            <ComboBoxItem Content="Дом с участком"/>
                            <ComboBoxItem Content="Другое"/>
                        </ComboBox>
                        <TextBlock Text="Есть ли другие животные?" Foreground="#667EEA" FontSize="13" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbOtherPets" Height="42" FontSize="14" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,0,15">
                            <ComboBoxItem Content="Нет" IsSelected="True"/>
                            <ComboBoxItem Content="1-2 животных"/>
                            <ComboBoxItem Content="Более 2 животных"/>
                        </ComboBox>
                        <TextBlock Text="Есть ли дети?" Foreground="#667EEA" FontSize="13" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbChildren" Height="42" FontSize="14" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,0,15">
                            <ComboBoxItem Content="Нет" IsSelected="True"/>
                            <ComboBoxItem Content="Да, до 7 лет"/>
                            <ComboBoxItem Content="Да, старше 7 лет"/>
                        </ComboBox>
                        <TextBlock Text="Опыт содержания животных" Foreground="#667EEA" FontSize="13" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbExperience" Height="42" FontSize="14" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,0,15">
                            <ComboBoxItem Content="Нет опыта" IsSelected="True"/>
                            <ComboBoxItem Content="Был опыт"/>
                            <ComboBoxItem Content="Сейчас есть животные"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Дополнительная информация -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="📝 Дополнительная информация" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                        <TextBlock Text="Почему вы хотите взять именно это животное?" Foreground="#667EEA" FontSize="13" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtReason" Height="80" Padding="12,10" FontSize="13" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" Margin="0,0,0,15"/>
                        <TextBlock Text="Дополнительные комментарии" Foreground="#667EEA" FontSize="13" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtNotes" Height="80" Padding="12,10" FontSize="13" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,20,0,0" BorderBrush="#E9ECEF" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="BtnCancel_Click" Width="120" Height="45" Margin="0,0,15,0" Background="#95A5A6" Foreground="White" FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>
                <Button Content="✓ Отправить заявку" Click="BtnSubmit_Click" Width="160" Height="45" Foreground="White" Background="{StaticResource PrimaryGradient}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>