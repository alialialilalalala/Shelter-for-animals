<Window x:Class="AnimalShelterAI.AnimalDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Информация о животном"
        Height="650" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F7FA"
                Icon="C:\Users\alialialilalala\Pictures\Screenshots\shelter.png"

        >

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Opacity="0.12" Color="#000000"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="0,5"/>
        </Style>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource SuccessGradient}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🐾" FontSize="32" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock x:Name="txtAnimalName" Text="Имя животного" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="txtAnimalStatus" Text="Статус" FontSize="13" Foreground="#B0BEC5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Фото и основная информация -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
					<!-- Фото -->
					<Border Grid.Column="0" Width="200" Height="200" CornerRadius="12" Background="#F1F3F5" BorderBrush="#DEE2E6" BorderThickness="2" Margin="0,0,20,0">
						<Grid>
							<!-- Изображение (видно, когда есть фото) -->
							<Image x:Name="imgPhoto"
								   Stretch="UniformToFill"
								   Width="200"
								   Height="200">
								<Image.Style>
									<Style TargetType="Image">
										<Setter Property="Visibility" Value="Collapsed"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding HasPhoto}" Value="True">
												<Setter Property="Visibility" Value="Visible"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Image.Style>
							</Image>

							<!-- Заглушка (видно, когда нет фото) -->
							<Border Background="#F1F3F5"
									Width="200"
									Height="200"
									CornerRadius="12">
								<Border.Style>
									<Style TargetType="Border">
										<Setter Property="Visibility" Value="Visible"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding HasPhoto}" Value="True">
												<Setter Property="Visibility" Value="Collapsed"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Border.Style>
								<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
									<TextBlock Text="🐾" FontSize="64" Foreground="#BDC3C7"/>
									<TextBlock Text="Нет фото" FontSize="14" Foreground="#95A5A6" Margin="0,10,0,0"/>
								</StackPanel>
							</Border>
						</Grid>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Краткая информация" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Кличка:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtName" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Вид:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtType" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Порода:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtBreed" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Пол:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtGender" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Возраст:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtAge" Style="{StaticResource InfoValue}"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Детальная информация -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Детальная информация" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Вес:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtWeight" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Окрас:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" x:Name="txtColor" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Статус:" Style="{StaticResource InfoLabel}"/>
                            <Border Grid.Row="1" Grid.Column="1" x:Name="borderStatus" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left">
                                <TextBlock x:Name="txtStatus" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Здоровье:" Style="{StaticResource InfoLabel}"/>
                            <Border Grid.Row="1" Grid.Column="3" x:Name="borderHealth" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left">
                                <TextBlock x:Name="txtHealth" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата поступления:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtAdmissionDate" Style="{StaticResource InfoValue}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Описание -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Описание" Style="{StaticResource SectionHeader}"/>
                        <TextBlock x:Name="txtDescription" FontSize="14" Foreground="#34495E" TextWrapping="Wrap" LineHeight="1.5"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,15,0,0" BorderBrush="#E9ECEF" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnEdit" Content="✏️ Редактировать" Click="BtnEdit_Click" Width="180" Height="40" Margin="0,0,12,0" Style="{StaticResource PrimaryButton}" Visibility="Collapsed"/>
                <Button x:Name="btnAdopt" Content="🏠 Подать заявку" Click="BtnAdopt_Click" Width="180" Height="40" Margin="0,0,12,0" Style="{StaticResource PrimaryButton}"/>
                <Button Content="Закрыть" Click="BtnClose_Click" Width="120" Height="40" Background="#95A5A6" Foreground="White" FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>