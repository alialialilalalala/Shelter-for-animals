<Window x:Class="AnimalShelterAI.AnimalEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Животное - Приют" Height="780" Width="850"
        WindowStartupLocation="CenterOwner" Background="#F8F9FA" ResizeMode="CanResizeWithGrip"
                Icon="C:\Users\alialialilalala\Pictures\Screenshots\shelter.png"
>

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="8" Opacity="0.12" Color="#000000"/>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}"  CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🐾" FontSize="32" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock x:Name="txtTitle" Text="Добавление животного" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Заполните информацию о питомце" FontSize="13" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <Border Width="200" Height="200" CornerRadius="12" Background="#F1F3F5" BorderBrush="#DEE2E6" BorderThickness="2" Cursor="Hand" MouseLeftButtonDown="PhotoBorder_MouseLeftButtonDown">
                                <Image x:Name="imgPhoto" Stretch="UniformToFill" ToolTip="Нажмите для выбора фото"/>
                            </Border>
                            <Button Content="📷 Выбрать фото" Click="BtnSelectPhoto_Click" Margin="0,10,0,0" Height="32" Background="#667EEA" Foreground="White" BorderThickness="0" FontSize="12" Cursor="Hand"/>
                            <Button x:Name="BtnRemovePhoto" Content="❌ Удалить фото" Click="BtnRemovePhoto_Click" Margin="0,5,0,0" Height="32" Background="#E53E3E" Foreground="White" BorderThickness="0" FontSize="12" Cursor="Hand" Visibility="Collapsed"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Кличка *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox x:Name="txtName" Height="48" FontSize="15" Padding="12,0" BorderBrush="#D1D5DB" BorderThickness="1" TextChanged="txtName_TextChanged"/>
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Вид *" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <ComboBox x:Name="cmbType" Height="48" FontSize="14" SelectionChanged="cmbType_SelectionChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Порода" Foreground="#7F8C8D" FontSize="13" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="cmbBreed" Height="36" FontSize="14" Padding="10,8" BorderBrush="#E1E8ED" BorderThickness="1"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Основные характеристики" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="#2C3E50"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Пол" Margin="0,0,0,8" FontWeight="Medium"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="rbMale" Content="Мужской" IsChecked="True" Margin="0,0,30,0"/>
                                    <RadioButton x:Name="rbFemale" Content="Женский"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Возраст (лет)" Margin="0,0,0,8" FontWeight="Medium"/>
                                <TextBox x:Name="txtAge" Height="42"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Вес (кг)" Margin="0,0,0,8" FontWeight="Medium"/>
                                <TextBox x:Name="txtWeight" Height="42"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Окрас" Margin="0,16,0,8" FontWeight="Medium"/>
                        <TextBox x:Name="txtColor" Height="42"/>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Дополнительная информация" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="#2C3E50"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Дата поступления *" Margin="0,0,0,8"/>
                                <DatePicker x:Name="dpAdmissionDate" Height="42"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Статус *" Margin="0,0,0,8"/>
                                <ComboBox x:Name="cmbStatus" Height="42"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Состояние здоровья" Margin="0,16,0,8"/>
                        <ComboBox x:Name="cmbHealthStatus" Height="42"/>
                        <TextBlock Text="Описание" Margin="0,16,0,8"/>
                        <TextBox x:Name="txtDescription" Height="110" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="14"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,10,0,0" BorderBrush="#E9ECEF" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="btnCancel_Click" Width="130" Height="48" Margin="0,0,12,0"/>
                <Button x:Name="btnSave" Content="Сохранить животное" Click="btnSave_Click" Width="180" Height="48" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>