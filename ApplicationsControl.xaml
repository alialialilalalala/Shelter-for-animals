<UserControl x:Class="AnimalShelterAI.ApplicationsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <DropShadowEffect x:Key="HeaderShadow" Color="#20000000" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
        <DropShadowEffect x:Key="CardShadow" Color="#20000000" BlurRadius="10" ShadowDepth="3" Opacity="0.15"/>
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E1E8ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E1E8ED" BorderThickness="0,0,0,1" Padding="20" Effect="{StaticResource HeaderShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Фильтр - СЛЕВА с подписью -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Статус заявки:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" Foreground="#4A5568"/>
                    <ComboBox x:Name="CmbStatusFilter" Width="160" Height="36" SelectionChanged="CmbStatusFilter_SelectionChanged" Style="{StaticResource ModernComboBox}">
                        <ComboBoxItem Content="Все заявки" IsSelected="True"/>
                        <ComboBoxItem Content="Ожидают"/>
                        <ComboBoxItem Content="Одобрены"/>
                        <ComboBoxItem Content="Отклонены"/>
                    </ComboBox>
                </StackPanel>

                <!-- Кнопка - СПРАВА -->
                <Button Grid.Column="1" Content="🔄 Обновить" Click="BtnRefresh_Click" Margin="10,0,0,0" Width="130" Height="36" Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25">
            <ItemsControl x:Name="ApplicationsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" BorderBrush="#E1E8ED" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="#2C3E50"><Run Text="Заявка #"/><Run Text="{Binding ApplicationId}"/></TextBlock>
                                            <TextBlock FontSize="13" Foreground="#7F8C8D"><Run Text="Животное: "/><Run Text="{Binding AnimalName}" FontWeight="SemiBold" Foreground="#2C3E50"/><Run Text=" ("/><Run Text="{Binding AnimalType}"/><Run Text=")"/></TextBlock>
                                            <TextBlock FontSize="13" Foreground="#7F8C8D"><Run Text="Заявитель: "/><Run Text="{Binding UserFullName}" FontWeight="SemiBold" Foreground="#2C3E50"/></TextBlock>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{Binding StatusColor}" CornerRadius="6" Padding="12,6" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock FontSize="12" Foreground="#7F8C8D"><Run Text="Дата подачи: "/><Run Text="{Binding ApplicationDate, StringFormat='dd.MM.yyyy HH:mm'}" FontWeight="SemiBold"/></TextBlock>
                                        <TextBlock FontSize="12" Foreground="#7F8C8D" Margin="20,0,0,0" Visibility="{Binding DecisionDateVisibility}"><Run Text="Дата решения: "/><Run Text="{Binding DecisionDate, StringFormat='dd.MM.yyyy HH:mm'}" FontWeight="SemiBold"/></TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Notes}" FontSize="13" Foreground="#34495E" Margin="0,10,0,0" TextWrapping="Wrap" Visibility="{Binding NotesVisibility}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="15,0,0,0">
                                    <Button Content="👁 Просмотр" Tag="{Binding ApplicationId}" Click="BtnView_Click" Width="160" Height="36" Margin="0,0,0,8" Style="{StaticResource PrimaryButton}"/>
                                    <Button Content="✓ Одобрить" Tag="{Binding ApplicationId}" Click="BtnApprove_Click" Width="160" Height="36" Margin="0,0,0,8" Style="{StaticResource SuccessButton}" Visibility="{Binding ApproveButtonVisibility}"/>
                                    <Button Content="✗ Отклонить" Tag="{Binding ApplicationId}" Click="BtnReject_Click" Width="160" Height="36" Style="{StaticResource DangerButton}" Visibility="{Binding RejectButtonVisibility}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>