<UserControl x:Class="AnimalShelterAI.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="25">
        <StackPanel>
            <!-- Заголовок -->
            <TextBlock Text="Панель управления" 
                       FontSize="28" 
                       FontWeight="SemiBold" 
                       Foreground="#2C3E50"
                       Margin="0,0,0,25"/>

            <!-- Карточки статистики -->
            <UniformGrid Columns="4" Margin="0,0,0,25" x:Name="StatsGrid">
                <!-- Всего животных -->
                <Border Margin="0,0,15,15" 
                        Background="White" 
                        BorderBrush="#E1E8ED" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="20"
                        Effect="{StaticResource CardShadow}"
                        Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#20000000" 
                                                              BlurRadius="15" 
                                                              ShadowDepth="5" 
                                                              Opacity="0.25"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="🐕" FontSize="24" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TotalAnimals" 
                                       Text="0" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Foreground="#3498DB"
                                       Margin="0,5,0,0"/>
                            <TextBlock Text="Всего животных" 
                                       FontSize="13" 
                                       Foreground="#7F8C8D"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" 
                                Background="#EBF5FB" 
                                CornerRadius="8" 
                                Width="50" 
                                Height="50"
                                VerticalAlignment="Center">
                            <TextBlock Text="📊" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Ищут дом -->
                <Border Margin="0,0,15,15" 
                        Background="White" 
                        BorderBrush="#E1E8ED" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="20"
                        Effect="{StaticResource CardShadow}"
                        Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#27AE60"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#20000000" 
                                                              BlurRadius="15" 
                                                              ShadowDepth="5" 
                                                              Opacity="0.25"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="🏠" FontSize="24" Margin="0,0,0,5"/>
                            <TextBlock x:Name="AvailableAnimals" 
                                       Text="0" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Foreground="#27AE60"
                                       Margin="0,5,0,0"/>
                            <TextBlock Text="Ищут дом" 
                                       FontSize="13" 
                                       Foreground="#7F8C8D"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" 
                                Background="#E8F8F5" 
                                CornerRadius="8" 
                                Width="50" 
                                Height="50"
                                VerticalAlignment="Center">
                            <TextBlock Text="✓" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Заявки -->
                <Border Margin="0,0,15,15" 
                        Background="White" 
                        BorderBrush="#E1E8ED" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="20"
                        Effect="{StaticResource CardShadow}"
                        Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#F39C12"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#20000000" 
                                                              BlurRadius="15" 
                                                              ShadowDepth="5" 
                                                              Opacity="0.25"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="📋" FontSize="24" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TotalApplications" 
                                       Text="0" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Foreground="#F39C12"
                                       Margin="0,5,0,0"/>
                            <TextBlock Text="Заявки" 
                                       FontSize="13" 
                                       Foreground="#7F8C8D"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" 
                                Background="#FEF5E7" 
                                CornerRadius="8" 
                                Width="50" 
                                Height="50"
                                VerticalAlignment="Center">
                            <TextBlock Text="📝" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Задачи -->
                <Border Margin="0,0,0,15" 
                        Background="White" 
                        BorderBrush="#E1E8ED" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="20"
                        Effect="{StaticResource CardShadow}"
                        Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#9B59B6"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#20000000" 
                                                              BlurRadius="15" 
                                                              ShadowDepth="5" 
                                                              Opacity="0.25"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="✅" FontSize="24" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TotalTasks" 
                                       Text="0" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Foreground="#9B59B6"
                                       Margin="0,5,0,0"/>
                            <TextBlock Text="Активные задачи" 
                                       FontSize="13" 
                                       Foreground="#7F8C8D"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" 
                                Background="#F4ECF7" 
                                CornerRadius="8" 
                                Width="50" 
                                Height="50"
                                VerticalAlignment="Center">
                            <TextBlock Text="✓" 
                                       FontSize="24" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Таблица последних животных -->
            <Border Background="White" 
                    BorderBrush="#E1E8ED" 
                    BorderThickness="1" 
                    CornerRadius="12" 
                    Padding="20"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="Недавно поступившие животные" 
                                   FontSize="18" 
                                   FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <DataGrid x:Name="AnimalsGrid" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              HeadersVisibility="Column" 
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              RowBackground="White"
                              AlternatingRowBackground="#F8F9FA"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Кличка" 
                                                Binding="{Binding Name}" 
                                                Width="120"
                                                HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Вид" 
                                                Binding="{Binding Type}" 
                                                Width="100"
                                                HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Порода" 
                                                Binding="{Binding Breed}" 
                                                Width="120"
                                                HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Пол" 
                                                Binding="{Binding Gender}" 
                                                Width="70"
                                                HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Возраст" 
                                                Binding="{Binding Age}" 
                                                Width="80"
                                                HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Статус" 
                                                Binding="{Binding Status}" 
                                                Width="150"
                                                HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>

    <UserControl.Resources>
        <DropShadowEffect x:Key="CardShadow" 
                          Color="#20000000" 
                          BlurRadius="10" 
                          ShadowDepth="3" 
                          Opacity="0.15"/>
        
        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#E1E8ED"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>
    </UserControl.Resources>
</UserControl>