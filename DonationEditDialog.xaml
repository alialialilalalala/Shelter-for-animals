<Window x:Class="AnimalShelterAI.DonationEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пожертвование - Приют" Height="600" Width="650"
                Icon="C:\Users\alialialilalala\Pictures\Screenshots\shelter.png"

        WindowStartupLocation="CenterOwner" Background="#F8F9FA" ResizeMode="NoResize">

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="8" Opacity="0.12" Color="#000000"/>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💰" FontSize="32" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock x:Name="txtWindowTitle" Text="Новое пожертвование" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Заполните информацию о пожертвовании" FontSize="13" Foreground="#B0BEC5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Дата пожертвования *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <DatePicker x:Name="dpDonationDate" Height="42" FontSize="14" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,0,16"/>
                    <TextBlock Text="Сумма *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtAmount" Height="42" FontSize="14" Padding="12,10" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,0,16"/>
                    <TextBlock Text="Тип пожертвования" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cmbDonationType" Height="42" FontSize="14" Padding="12,10" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,0,16">
                        <ComboBoxItem Content="Наличные" IsSelected="True"/>
                        <ComboBoxItem Content="Банковский перевод"/>
                        <ComboBoxItem Content="Корм"/>
                        <ComboBoxItem Content="Лекарства"/>
                        <ComboBoxItem Content="Вещи"/>
                        <ComboBoxItem Content="Другое"/>
                    </ComboBox>
                    <TextBlock Text="Имя донора (если не анонимно)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtDonorName" Height="42" FontSize="14" Padding="12,10" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,0,16"/>
                    <CheckBox x:Name="chkIsAnonymous" Content="Анонимное пожертвование" FontSize="14" Margin="0,0,0,16" Checked="ChkIsAnonymous_Checked" Unchecked="ChkIsAnonymous_Unchecked"/>
                    <TextBlock Text="Примечания" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtNotes" Height="80" FontSize="14" Padding="12,10" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" BorderBrush="#D1D5DB" BorderThickness="1"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,10,0,0" BorderBrush="#E9ECEF" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="BtnCancel_Click" Width="130" Height="48" Margin="0,0,12,0"/>
                <Button x:Name="btnSave" Content="Сохранить" Click="BtnSave_Click" Width="130" Height="48" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>