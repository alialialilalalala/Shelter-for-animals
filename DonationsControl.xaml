<UserControl x:Class="AnimalShelterAI.DonationsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <DropShadowEffect x:Key="HeaderShadow" Color="#20000000" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
        <DropShadowEffect x:Key="CardShadow" Color="#20000000" BlurRadius="10" ShadowDepth="3" Opacity="0.15"/>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2E8F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#E1E8ED"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E1E8ED" BorderThickness="0,0,0,1" Padding="20" Effect="{StaticResource HeaderShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Статистика - СЛЕВА -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#E8F5E9" CornerRadius="8" Padding="12,8" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰 Общая сумма: " FontSize="13" FontWeight="SemiBold" Foreground="#27AE60"/>
                            <TextBlock x:Name="txtTotalSum" Text="0 руб." FontSize="16" FontWeight="Bold" Foreground="#27AE60"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF3E0" CornerRadius="8" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊 Всего пожертвований: " FontSize="13" FontWeight="SemiBold" Foreground="#F39C12"/>
                            <TextBlock x:Name="txtTotalCount" Text="0" FontSize="16" FontWeight="Bold" Foreground="#F39C12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Кнопки - СПРАВА -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="➕ Добавить пожертвование" Click="BtnAdd_Click" Width="220" Height="36" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Cursor=""/>
                    <Button Content="📥 Экспорт в Excel" Click="BtnExport_Click" Width="150" Height="36" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="DonationsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" BorderThickness="0" GridLinesVisibility="None" RowBackground="White" AlternatingRowBackground="#F8F9FA" CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column" Margin="25" RowHeight="50" SelectionChanged="DonationsGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding DonationId}" Width="60" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding DonationDate, StringFormat='dd.MM.yyyy'}" Width="100" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat='{}{0:N2} руб.'}" Width="120" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding DonationType}" Width="120" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                <DataGridTextColumn Header="Имя донора" Binding="{Binding DonorName}" Width="180" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                <DataGridCheckBoxColumn Header="Анонимно" Binding="{Binding IsAnonymous}" Width="80" HeaderStyle="{StaticResource DataGridHeaderStyle}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Примечания" Binding="{Binding Notes}" Width="200" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                <DataGridTemplateColumn Header="Действия" Width="100" HeaderStyle="{StaticResource DataGridHeaderStyle}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="✏️" Tag="{Binding DonationId}" Click="BtnEdit_Click" Margin="2" Padding="8" Background="#FFF3E0" Foreground="#ED8936" Style="{StaticResource IconButton}" ToolTip="Редактировать"/>
                                <Button Content="🗑" Tag="{Binding DonationId}" Click="BtnDelete_Click" Margin="2" Padding="8" Background="#FFEBEE" Foreground="#E53E3E" Style="{StaticResource IconButton}" ToolTip="Удалить"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>