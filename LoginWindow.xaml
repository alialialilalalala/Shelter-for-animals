<Window x:Class="AnimalShelterAI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - Приют для животных"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow" 
                          BlurRadius="30" 
                          ShadowDepth="0" 
                          Opacity="0.4" 
                          Color="Black"/>

        <LinearGradientBrush x:Key="MainGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667EEA" Offset="0"/>
            <GradientStop Color="#764BA2" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ButtonGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#667EEA" Offset="0"/>
            <GradientStop Color="#764BA2" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="GradientButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Border Background="Transparent" CornerRadius="20" Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="600"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <Border Grid.Column="0" CornerRadius="20,0,0,20" Background="{StaticResource MainGradient}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                    <TextBlock Text="🐾" FontSize="80" HorizontalAlignment="Center" Foreground="White" Opacity="0.9"/>
                    <TextBlock Text="Приют" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,30,0,0"/>

                    <TextBlock Text="Добро пожаловать!" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,10"/>
                    <TextBlock Text="Пожалуйста, войдите в систему, для дальнейшего использования приложения" FontSize="14" Foreground="White" Opacity="0.8" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                    <Border Height="2" Width="50" Background="White" CornerRadius="1" Margin="0,40,0,0" HorizontalAlignment="Center"/>
                    <TextBlock Text="💙 200+ животных нашли дом" FontSize="13" Foreground="White" Opacity="0.7" TextAlignment="Center" Margin="0,30,0,0"/>
                    <TextBlock Text="✨Мы ценим вашу помощь" FontSize="13" Foreground="White" Opacity="0.7" TextAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Правая панель -->
            <Border Grid.Column="1" CornerRadius="0,20,20,0" Background="White">
                <Grid>
                    <!-- Кнопка закрытия -->
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Top"
                            Width="35" Height="35"
                            Background="Transparent" 
                            BorderThickness="0"
                            Foreground="#A0AEC0"
                            Cursor="Hand"
                            Click="BtnClose_Click"
                            FontSize="16"
                            Margin="0,10,15,0"/>

                    <!-- Форма входа -->
                    <StackPanel VerticalAlignment="Center" Margin="50,0,50,0">
                        <TextBlock Text="🐾" FontSize="45" HorizontalAlignment="Center" Foreground="#667EEA"/>
                        <TextBlock Text="Вход в аккаунт" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#2D3748" Margin="0,10,0,5"/>
                        <TextBlock Text="Введите свои данные для входа" FontSize="14" Foreground="#A0AEC0" HorizontalAlignment="Center" Margin="0,0,0,35"/>

                        <TextBlock Text="Логин" FontSize="14" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,8"/>
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Background="#F7FAFC" Margin="0,0,0,20">
                            <TextBox x:Name="txtUsername" Style="{StaticResource ModernTextBox}"/>
                        </Border>

                        <TextBlock Text="Пароль" FontSize="14" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,8"/>
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Background="#F7FAFC" Margin="0,0,0,20">
                            <PasswordBox x:Name="txtPassword" Style="{StaticResource ModernPasswordBox}"/>
                        </Border>

                        <CheckBox x:Name="chkRememberMe" Content="Запомнить меня" Foreground="#4A5568" Margin="0,0,0,30" FontSize="13"/>

                        <Button x:Name="btnLogin" Content="ВОЙТИ" Click="BtnLogin_Click" Style="{StaticResource GradientButton}"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                            <TextBlock Text="Нет аккаунта? " Foreground="#A0AEC0" FontSize="13" Margin="0,5,0,0"/>
                            <Button Content="Зарегистрироваться" Click="BtnRegister_Click" Background="Transparent" BorderThickness="0" Foreground="#667EEA" Padding="5,0" Cursor="Hand" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>