<Window x:Class="AnimalShelterAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Приют для животных - Система управления"
        Height="800"
        Width="1300"
        WindowStartupLocation="CenterScreen"
        
        Background="Transparent"
        Icon="C:\Users\alialialilalala\Pictures\Screenshots\shelter.png"
        >

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow" 
                  BlurRadius="30" 
                  ShadowDepth="0" 
                  Opacity="0.4" 
                  Color="Black"/>

        <!-- Градиент для левого меню как в окне входа -->
        <LinearGradientBrush x:Key="MenuGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#667EEA" Offset="0"/>
            <GradientStop Color="#764BA2" Offset="1"/>
        </LinearGradientBrush>

        <!-- Светлый градиент для шапки -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#F8F9FA" Offset="1"/>
        </LinearGradientBrush>

        <!-- Тень -->
        <DropShadowEffect x:Key="HeaderShadow"
                          Color="#20000000"
                          BlurRadius="8"
                          ShadowDepth="2"
                          Opacity="0.08"/>

        <!-- Стиль кнопок меню -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFFFFF20"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20" Effect="{StaticResource WindowShadow}">

        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню - градиент -->
        <Border Grid.Column="0"
                Background="{StaticResource MenuGradient}"
                BorderBrush="#00000020"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок меню -->
                <Border Grid.Row="0" Background="{StaticResource MenuGradient}" Padding="20,20" BorderBrush="#FFFFFF20" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="🐾"
                                   FontSize="36"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"
                                   Foreground="White"
                                   Opacity="0.9"/>
                        <TextBlock Text="Приют"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Система управления"
                                   Foreground="#E2E8F0"
                                   Opacity="0.7"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Кнопки меню -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible">
                    <StackPanel Margin="12,20">
                            <Button x:Name="BtnProfile" Content="👤 Мой профиль" Click="BtnProfile_Click" HorizontalAlignment="Stretch"
 Style="{StaticResource MenuButtonStyle}"/>
                            <Button x:Name="BtnDashboard"
                                Content="📊 Дашборд"
                                Click="BtnDashboard_Click"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Button x:Name="BtnAnimals"
                                Content="🐕 Животные"
                                Click="BtnAnimals_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Separator Margin="0,15" Height="1" Background="#FFFFFF20"/>

                        <TextBlock Text="УПРАВЛЕНИЕ"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   Foreground="#E2E8F0"
                                   Opacity="0.6"
                                   Margin="20,10,5,8"/>

                        <Button x:Name="BtnApplications"
                                Content="📋 Заявки"
                                Click="BtnApplications_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Button x:Name="BtnTasks"
                                Content="✅ Задачи"
                                Click="BtnTasks_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Button x:Name="BtnMedical"
                                Content="🏥 Медицина"
                                Click="BtnMedical_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Button x:Name="BtnDonations" 
                                Content="💰 Пожертвования" 
                                Click="BtnDonations_Click" 
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Separator Margin="0,15" Height="1" Background="#FFFFFF20"/>

                        <TextBlock Text="АДМИНИСТРИРОВАНИЕ"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   Foreground="#E2E8F0"
                                   Opacity="0.6"
                                   Margin="20,10,5,8"/>

                        <Button x:Name="BtnUsers"
                                Content="👥 Пользователи"
                                Click="BtnUsers_Click"
                                Style="{StaticResource MenuButtonStyle}"/>

                        <Button x:Name="BtnReports"
                                Content="📈 Отчеты"
                                Click="BtnReports_Click"
                                Style="{StaticResource MenuButtonStyle}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Кнопка выхода -->
                <Border Grid.Row="2"
                        BorderBrush="#FFFFFF20"
                        BorderThickness="0,1,0,0"
                        Background="#00000020">
                    <Button x:Name="BtnLogout"
                            Content="🚪 Выйти"
                            Click="BtnLogout_Click"
                            Height="55"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#FECDD3"
                            FontSize="14"
                            FontWeight="SemiBold"
                            HorizontalContentAlignment="Left"
                            Padding="20,0"
                            Cursor="Hand"
                            Style="{StaticResource MenuButtonStyle}">
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Button.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Button.Foreground).(SolidColorBrush.Color)"
                                                      To="#F56565" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Button.Foreground).(SolidColorBrush.Color)"
                                                      To="#FECDD3" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Column="1" Background="#F8FAFC">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0"
                    Background="{StaticResource HeaderGradient}"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,0,0,1"
                    Padding="25,18"
                    Effect="{StaticResource HeaderShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="txtGreeting"
                                   Text="Добро пожаловать!"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#2D3748"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtUserRole"
                                   Text="Роль: Пользователь"
                                   FontSize="13"
                                   Foreground="#718096"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="txtUserName"
                                   Text="Пользователь"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#2D3748"
                                   VerticalAlignment="Center"
                                   Margin="0,0,15,0"/>
                        <Border Background="{StaticResource MenuGradient}"
                                CornerRadius="20"
                                Padding="12,6"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="txtUserRoleBadge"
                                       Text="User"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Контент -->
            <Frame x:Name="MainFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>
        </Grid>
    </Grid>
 </Border>
</Window>