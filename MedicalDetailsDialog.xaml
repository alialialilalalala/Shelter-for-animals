<Window x:Class="AnimalShelterAI.MedicalDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Медицинская карта - Приют" Height="600" Width="750"
                Icon="C:\Users\alialialilalala\Pictures\Screenshots\shelter.png"

        WindowStartupLocation="CenterOwner" Background="#F5F7FA" ResizeMode="CanResize">

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Opacity="0.12" Color="#000000"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="0,5"/>
        </Style>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🏥" FontSize="32" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock x:Name="txtTitle" Text="Медицинская запись" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="txtSubtitle" Text="Информация о лечении" FontSize="13" Foreground="#B0BEC5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="📅 Информация о визите" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Дата осмотра:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtRecordDate" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Следующий визит:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" x:Name="txtNextVisit" Style="{StaticResource InfoValue}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="🐾 Пациент" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Животное:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtAnimalName" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Вид/Порода:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" x:Name="txtAnimalType" Style="{StaticResource InfoValue}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ветеринар:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtVetName" Style="{StaticResource InfoValue}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="📋 Диагноз и лечение" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Text="Диагноз:" Style="{StaticResource InfoLabel}"/>
                        <Border Background="#F8F9FA" CornerRadius="8" Padding="12" Margin="0,0,0,15">
                            <TextBlock x:Name="txtDiagnosis" FontSize="14" Foreground="#2C3E50" TextWrapping="Wrap"/>
                        </Border>
                        <TextBlock Text="Назначенное лечение:" Style="{StaticResource InfoLabel}"/>
                        <Border Background="#F8F9FA" CornerRadius="8" Padding="12" Margin="0,0,0,15">
                            <TextBlock x:Name="txtTreatment" FontSize="14" Foreground="#2C3E50" TextWrapping="Wrap"/>
                        </Border>
                        <TextBlock Text="Заметки:" Style="{StaticResource InfoLabel}"/>
                        <Border Background="#F8F9FA" CornerRadius="8" Padding="12">
                            <TextBlock x:Name="txtNotes" FontSize="13" Foreground="#7F8C8D" FontStyle="Italic" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,15,0,0" BorderBrush="#E9ECEF" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnEdit" Content="✏️ Редактировать" Click="BtnEdit_Click" Width="180" Height="40" Margin="0,0,12,0" Style="{StaticResource PrimaryButton}"/>
                <Button Content="Закрыть" Click="BtnClose_Click" Width="120" Height="40" Background="#95A5A6" Foreground="White" FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>