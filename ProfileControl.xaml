<UserControl x:Class="AnimalShelterAI.ProfileControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20">
            <TextBlock Text="Мой профиль" FontSize="24" FontWeight="SemiBold" Foreground="#2D3748"/>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Личная информация -->
                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="👤 Личная информация" FontSize="18" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ФИО:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtFullName" Style="{StaticResource InfoValue}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Email:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtEmail" Style="{StaticResource InfoValue}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Телефон:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtPhone" Style="{StaticResource InfoValue}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Роль:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtRole" Style="{StaticResource InfoValue}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата регистрации:" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtRegDate" Style="{StaticResource InfoValue}"/>
                        </Grid>
                        <Button Content="✏️ Редактировать профиль" Click="BtnEditProfile_Click" Width="200" Height="36" HorizontalAlignment="Right" Margin="0,15,0,0" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </Border>

                <!-- Мои заявки -->
                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,20" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="📋 Мои заявки" FontSize="18" FontWeight="SemiBold" Foreground="#2D3748" Margin="0,0,0,16"/>

                        <ItemsControl x:Name="ApplicationsList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="8" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <StackPanel>
                                            <!-- Мини-фото животного -->
                                            <Border Height="100" Background="#F1F5F9" CornerRadius="8" Margin="0,0,0,8">
                                                <Grid>
                                                    <Image Source="{Binding PhotoUrl}" Stretch="UniformToFill" Width="100" Height="100" 
                                           Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <TextBlock Text="🐾" FontSize="32" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                               Visibility="{Binding HasPhoto, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}"/>
                                                </Grid>
                                            </Border>

                                            <TextBlock Text="{Binding AnimalName}" FontSize="16" FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock Text="{Binding AnimalType}" FontSize="12" Foreground="#64748B" Margin="0,4,0,8"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="Дата подачи:" FontSize="11" Foreground="#94A3B8"/>
                                                <TextBlock Text="{Binding ApplicationDate, StringFormat='dd.MM.yyyy'}" FontSize="11" FontWeight="SemiBold" Foreground="#334155" Margin="5,0,0,0"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8" Visibility="{Binding DecisionDateVisibility}">
                                                <TextBlock Text="Дата решения:" FontSize="11" Foreground="#94A3B8"/>
                                                <TextBlock Text="{Binding DecisionDate, StringFormat='dd.MM.yyyy'}" FontSize="11" FontWeight="SemiBold" Foreground="#334155" Margin="5,0,0,0"/>
                                            </StackPanel>

                                            <!-- Статус с цветом -->
                                            <Border Background="{Binding StatusColor}" CornerRadius="20" Padding="8,4" Margin="0,8,0,0" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                            </Border>

                                            
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="txtNoApplications" Text="📭 Нет заявок" FontSize="14" Foreground="#A0AEC0" HorizontalAlignment="Center" Margin="0,10,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>