<Window x:Class="AnimalShelterAI.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация - Приют для животных" 
        Height="750" 
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
                Icon="C:\Users\alialialilalala\Pictures\Screenshots\shelter.png"

        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow" 
                          BlurRadius="30" 
                          ShadowDepth="0" 
                          Opacity="0.4" 
                          Color="Black"/>

        <LinearGradientBrush x:Key="MainGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667EEA" Offset="0"/>
            <GradientStop Color="#764BA2" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="GradientButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource MainGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Border Background="Transparent" CornerRadius="20" Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="700"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <Border Grid.Column="0" CornerRadius="20,0,0,20" Background="{StaticResource MainGradient}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                    <TextBlock Text="🐾" FontSize="80" HorizontalAlignment="Center" Foreground="White" Opacity="0.9"/>
                    <TextBlock Text="Присоединяйтесь!" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,30,0,10"/>
                    <TextBlock Text="Создайте аккаунт и помогите животным найти новый дом" FontSize="14" Foreground="White" Opacity="0.8" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                    <Border Height="2" Width="50" Background="White" CornerRadius="1" Margin="0,40,0,0" HorizontalAlignment="Center"/>
                    <TextBlock Text="🌟 Стать волонтёром" FontSize="13" Foreground="White" Opacity="0.7" TextAlignment="Center" Margin="0,30,0,0"/>
                    <TextBlock Text="❤️ Помочь животным" FontSize="13" Foreground="White" Opacity="0.7" TextAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Правая панель -->
            <Border Grid.Column="1" CornerRadius="0,20,20,0" Background="White">
                <Grid>
                    <!-- Кнопка закрытия -->
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Top"
                            Width="35" Height="35"
                            Background="Transparent" 
                            BorderThickness="0"
                            Foreground="#A0AEC0"
                            Cursor="Hand"
                            Click="BtnClose_Click"
                            FontSize="16"
                            Margin="0,10,15,0"/>

                    <!-- Форма регистрации -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,20,0,0">
                        <StackPanel Margin="50,20,50,30">
                            <TextBlock Text="🐾" FontSize="35" HorizontalAlignment="Center" Foreground="#667EEA"/>
                            <TextBlock Text="Создание аккаунта" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#2D3748" Margin="0,5,0,5"/>
                            <TextBlock Text="Заполните форму для регистрации" FontSize="13" Foreground="#A0AEC0" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                            <!-- 2 колонки -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Имя *" FontSize="13" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,6"/>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Background="#F7FAFC" Margin="0,0,0,15">
                                        <TextBox x:Name="txtFirstName" Style="{StaticResource ModernTextBox}"/>
                                    </Border>

                                    <TextBlock Text="Email *" FontSize="13" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,6"/>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Background="#F7FAFC" Margin="0,0,0,15">
                                        <TextBox x:Name="txtEmail" Style="{StaticResource ModernTextBox}"/>
                                    </Border>

                                    <TextBlock Text="Логин *" FontSize="13" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,6"/>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Background="#F7FAFC" Margin="0,0,0,15">
                                        <TextBox x:Name="txtUsername" Style="{StaticResource ModernTextBox}"/>
                                    </Border>

                                    <TextBlock Text="Пароль *" FontSize="13" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,6"/>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Background="#F7FAFC" Margin="0,0,0,15">
                                        <PasswordBox x:Name="txtPassword" Style="{StaticResource ModernPasswordBox}"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Фамилия *" FontSize="13" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,6"/>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Background="#F7FAFC" Margin="0,0,0,15">
                                        <TextBox x:Name="txtLastName" Style="{StaticResource ModernTextBox}"/>
                                    </Border>

                                    <TextBlock Text="Телефон" FontSize="13" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,6"/>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Background="#F7FAFC" Margin="0,0,0,15">
                                        <TextBox x:Name="txtPhone" Style="{StaticResource ModernTextBox}"/>
                                    </Border>

                                    <TextBlock Text="Подтвердите пароль *" FontSize="13" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,6"/>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Background="#F7FAFC" Margin="0,0,0,15">
                                        <PasswordBox x:Name="txtConfirmPassword" Style="{StaticResource ModernPasswordBox}"/>
                                    </Border>

                                    <TextBlock Text="Роль" FontSize="13" FontWeight="SemiBold" Foreground="#4A5568" Margin="0,0,0,6"/>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Background="#F7FAFC">
                                        <ComboBox x:Name="cmbRole" Style="{StaticResource ModernComboBox}">
                                            <ComboBoxItem Content="👤 Пользователь" Tag="User" IsSelected="True"/>
                                            <ComboBoxItem Content="🤝 Волонтер" Tag="Volunteer"/>
                                        </ComboBox>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Button x:Name="btnRegister" Content="ЗАРЕГИСТРИРОВАТЬСЯ" Click="BtnRegister_Click" Style="{StaticResource GradientButton}" Margin="0,25,0,15"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                <TextBlock Text="Уже есть аккаунт? " Foreground="#A0AEC0" FontSize="13" Margin="0,5,0,0"/>
                                <Button Content="Войти" Click="BtnBackToLogin_Click" Background="Transparent" BorderThickness="0" Foreground="#667EEA" Padding="5,0" Cursor="Hand" FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>