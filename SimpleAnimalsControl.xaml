<UserControl x:Class="AnimalShelterAI.SimpleAnimalsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" 
                Background="White" 
                CornerRadius="8" 
                Margin="10"
                Padding="15"
                BorderBrush="#E0E0E0" 
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBox x:Name="txtSearch" 
                             Width="200" 
                             Padding="10,8"
                             Margin="0,0,10,0"/>

                    <Button Content="Поиск" 
                            Padding="20,8"
                            Background="#7B1FA2"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>

                <!-- Кнопки -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Добавить животное" 
                            Padding="15,8"
                            Background="#7B1FA2"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="0,0,10,0"/>

                    <Button Content="Экспорт" 
                            Padding="15,8"
                            Background="#2196F3"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Список животных -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      Margin="10">
            <StackPanel>
                <!-- Карточка животного 1 -->
                <Border Background="White" 
                        CornerRadius="8" 
                        Margin="0,0,0,10"
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1"
                        Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Изображение -->
                        <Border Grid.Column="0" 
                                Width="100" 
                                Height="100" 
                                Background="#E0E0E0" 
                                CornerRadius="8"
                                Margin="0,0,15,0"/>

                        <!-- Информация -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Барсик" 
                                       FontSize="18" 
                                       FontWeight="Bold"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Кошка • Дворовая • 2 года" 
                                       FontSize="14"
                                       Margin="0,0,0,3"/>
                            <TextBlock Text="Серый окрас, спокойный, любит спать на подоконнике" 
                                       FontSize="12"
                                       Foreground="#666666"
                                       TextWrapping="Wrap"
                                       MaxWidth="400"/>
                        </StackPanel>

                        <!-- Статус и кнопки -->
                        <StackPanel Grid.Column="2" 
                                    HorizontalAlignment="Right">
                            <Border Background="#4CAF50" 
                                    CornerRadius="4" 
                                    Padding="10,5"
                                    Margin="0,0,0,10">
                                <TextBlock Text="Доступен" 
                                           Foreground="White"
                                           FontWeight="Bold"/>
                            </Border>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Подробнее" 
                                        Padding="10,5"
                                        Margin="0,0,5,0"
                                        Background="Transparent"
                                        BorderBrush="#7B1FA2"
                                        BorderThickness="1"
                                        Foreground="#7B1FA2"/>
                                <Button Content="Забрать" 
                                        Padding="10,5"
                                        Background="#7B1FA2"
                                        Foreground="White"
                                        BorderThickness="0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Карточка животного 2 -->
                <Border Background="White" 
                        CornerRadius="8" 
                        Margin="0,0,0,10"
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1"
                        Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Изображение -->
                        <Border Grid.Column="0" 
                                Width="100" 
                                Height="100" 
                                Background="#E0E0E0" 
                                CornerRadius="8"
                                Margin="0,0,15,0"/>

                        <!-- Информация -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Шарик" 
                                       FontSize="18" 
                                       FontWeight="Bold"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Собака • Дворняга • 3 года" 
                                       FontSize="14"
                                       Margin="0,0,0,3"/>
                            <TextBlock Text="Черно-белый, энергичный, любит играть с мячом" 
                                       FontSize="12"
                                       Foreground="#666666"
                                       TextWrapping="Wrap"
                                       MaxWidth="400"/>
                        </StackPanel>

                        <!-- Статус и кнопки -->
                        <StackPanel Grid.Column="2" 
                                    HorizontalAlignment="Right">
                            <Border Background="#4CAF50" 
                                    CornerRadius="4" 
                                    Padding="10,5"
                                    Margin="0,0,0,10">
                                <TextBlock Text="Доступен" 
                                           Foreground="White"
                                           FontWeight="Bold"/>
                            </Border>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Подробнее" 
                                        Padding="10,5"
                                        Margin="0,0,5,0"
                                        Background="Transparent"
                                        BorderBrush="#7B1FA2"
                                        BorderThickness="1"
                                        Foreground="#7B1FA2"/>
                                <Button Content="Забрать" 
                                        Padding="10,5"
                                        Background="#7B1FA2"
                                        Foreground="White"
                                        BorderThickness="0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Карточка животного 3 -->
                <Border Background="White" 
                        CornerRadius="8" 
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1"
                        Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Изображение -->
                        <Border Grid.Column="0" 
                                Width="100" 
                                Height="100" 
                                Background="#E0E0E0" 
                                CornerRadius="8"
                                Margin="0,0,15,0"/>

                        <!-- Информация -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Мурка" 
                                       FontSize="18" 
                                       FontWeight="Bold"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Кошка • Сиамская • 1 год" 
                                       FontSize="14"
                                       Margin="0,0,0,3"/>
                            <TextBlock Text="Трехцветная, молодая, очень ласковая" 
                                       FontSize="12"
                                       Foreground="#666666"
                                       TextWrapping="Wrap"
                                       MaxWidth="400"/>
                        </StackPanel>

                        <!-- Статус и кнопки -->
                        <StackPanel Grid.Column="2" 
                                    HorizontalAlignment="Right">
                            <Border Background="#FF9800" 
                                    CornerRadius="4" 
                                    Padding="10,5"
                                    Margin="0,0,0,10">
                                <TextBlock Text="Карантин" 
                                           Foreground="White"
                                           FontWeight="Bold"/>
                            </Border>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Подробнее" 
                                        Padding="10,5"
                                        Margin="0,0,5,0"
                                        Background="Transparent"
                                        BorderBrush="#7B1FA2"
                                        BorderThickness="1"
                                        Foreground="#7B1FA2"/>
                                <Button Content="Забрать" 
                                        Padding="10,5"
                                        Background="#7B1FA2"
                                        Foreground="White"
                                        BorderThickness="0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>