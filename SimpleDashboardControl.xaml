<UserControl x:Class="AnimalShelterAI.SimpleDashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Приветствие -->
            <Border Grid.Row="0" 
                    Background="#7B1FA2" 
                    CornerRadius="10" 
                    Padding="20"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Добро пожаловать в систему управления приютом!" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock Text="Здесь вы можете управлять животными, заявками и задачами приюта." 
                               FontSize="14" 
                               Foreground="White"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Статистика -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Всего животных -->
                <Border Grid.Column="0" 
                        Background="White" 
                        CornerRadius="8" 
                        Margin="0,0,10,0"
                        Padding="15"
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🐾" 
                                   FontSize="30"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="50" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,5"/>
                        <TextBlock Text="Всего животных" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Ищут дом -->
                <Border Grid.Column="1" 
                        Background="White" 
                        CornerRadius="8" 
                        Margin="5,0,5,0"
                        Padding="15"
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🏠" 
                                   FontSize="30"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="35" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,5"/>
                        <TextBlock Text="Ищут дом" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Заявки -->
                <Border Grid.Column="2" 
                        Background="White" 
                        CornerRadius="8" 
                        Margin="5,0,5,0"
                        Padding="15"
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📋" 
                                   FontSize="30"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="12" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,5"/>
                        <TextBlock Text="Заявки" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Задачи -->
                <Border Grid.Column="3" 
                        Background="White" 
                        CornerRadius="8" 
                        Margin="10,0,0,0"
                        Padding="15"
                        BorderBrush="#E0E0E0" 
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="✅" 
                                   FontSize="30"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="8" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,5"/>
                        <TextBlock Text="Активные задачи" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Информация -->
            <Border Grid.Row="2" 
                    Background="White" 
                    CornerRadius="8" 
                    Padding="20"
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="О системе" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <TextBlock TextWrapping="Wrap">
                        <Run Text="Система управления приютом для животных позволяет:"/>
                        <LineBreak/>
                        <Run Text="• Управлять базой животных приюта"/>
                        <LineBreak/>
                        <Run Text="• Обрабатывать заявки на усыновление"/>
                        <LineBreak/>
                        <Run Text="• Назначать задачи волонтерам"/>
                        <LineBreak/>
                        <Run Text="• Ведение медицинских записей"/>
                        <LineBreak/>
                        <Run Text="• Генерация отчетов и статистики"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>