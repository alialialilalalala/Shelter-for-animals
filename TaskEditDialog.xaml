<Window x:Class="AnimalShelterAI.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задача - Приют"
        Height="750" Width="850"
        WindowStartupLocation="CenterOwner"
        Background="#F8F9FA"
                Icon="C:\Users\alialialilalala\Pictures\Screenshots\shelter.png"

        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="8" Opacity="0.12" Color="#000000"/>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✅" FontSize="32" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock x:Name="txtWindowTitle" Text="Новая задача" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Заполните информацию о задаче" FontSize="13" Foreground="#B0BEC5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Основная информация -->
                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Основная информация" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="#2C3E50"/>
                        <TextBlock Text="Название задачи *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtTaskTitle" Height="48" FontSize="15" Padding="12,0" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,0,16"/>
                        <TextBlock Text="Описание" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtDescription" Height="100" FontSize="14" Padding="12,10" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Срок выполнения *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <DatePicker x:Name="dpDueDate" Height="42" FontSize="14" BorderBrush="#D1D5DB" BorderThickness="1"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Статус" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <ComboBox x:Name="cmbStatus" Height="42" FontSize="14" BorderBrush="#D1D5DB" BorderThickness="1">
                                    <ComboBoxItem Content="⏳ Ожидает" Tag="Pending" IsSelected="True"/>
                                    <ComboBoxItem Content="🔄 В работе" Tag="InProgress"/>
                                    <ComboBoxItem Content="✅ Выполнена" Tag="Completed"/>
                                    <ComboBoxItem Content="❌ Отклонена" Tag="Rejected"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Назначение -->
                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Назначение" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="#2C3E50"/>
                        <TextBlock Text="Волонтёр *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="cmbVolunteer" Height="48" FontSize="14" Padding="12,0" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,0,16" DisplayMemberPath="DisplayName" SelectedValuePath="UserId"/>
                        <TextBlock Text="Животное (опционально)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="cmbAnimal" Height="48" FontSize="14" Padding="12,0" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,0,8" DisplayMemberPath="DisplayName" SelectedValuePath="AnimalId"/>
                        <TextBlock Text="* Не обязательно для заполнения" FontSize="11" Foreground="#95A5A6" Margin="5,5,0,10"/>
                    </StackPanel>
                </Border>

                <!-- Дополнительная информация -->
                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="Дополнительная информация" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="#2C3E50"/>
                        <TextBlock Text="Заметки" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtNotes" Height="100" FontSize="14" Padding="12,10" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" BorderBrush="#D1D5DB" BorderThickness="1"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,10,0,0" BorderBrush="#E9ECEF" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="BtnCancel_Click" Width="130" Height="48" Margin="0,0,12,0"/>
                <Button x:Name="btnSave" Content="Сохранить задачу" Click="BtnSave_Click" Width="180" Height="48" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>