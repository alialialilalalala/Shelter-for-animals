<UserControl x:Class="AnimalShelterAI.TasksControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <DropShadowEffect x:Key="HeaderShadow" Color="#20000000" BlurRadius="8" ShadowDepth="2" Opacity="0.1"/>
        <DropShadowEffect x:Key="CardShadow" Color="#20000000" BlurRadius="10" ShadowDepth="3" Opacity="0.15"/>
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E1E8ED"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E1E8ED" BorderThickness="0,0,0,1" Padding="20" Effect="{StaticResource HeaderShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Фильтр - СЛЕВА с подписью -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Статус задачи:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" Foreground="#4A5568"/>
                    <ComboBox x:Name="CmbStatusFilter" Width="180" Height="36"  Margin="0,0,10,0" SelectionChanged="CmbStatusFilter_SelectionChanged" Style="{StaticResource ModernComboBox}">
                        <ComboBoxItem Content="Все задачи" IsSelected="True"/>
                        <ComboBoxItem Content="Ожидает"/>
                        <ComboBoxItem Content="В работе"/>
                        <ComboBoxItem Content="Выполнена"/>
                        <ComboBoxItem Content="Отклонена"/>
                    </ComboBox>
                </StackPanel>

                <!-- Кнопки - СПРАВА -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnAdd" Content="➕ Добавить задачу" Click="BtnAdd_Click" Width="160" Height="36" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
                    <Button Content="🔄 Обновить" Click="BtnRefresh_Click" Width="130" Height="36" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25">
            <ItemsControl x:Name="TasksList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" BorderBrush="#E1E8ED" BorderThickness="1" Effect="{StaticResource CardShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Description}" FontSize="13" Foreground="#7F8C8D" TextWrapping="Wrap" Visibility="{Binding Descriptionvisibility}" Margin="0,0,0,10"/>
                                    <WrapPanel Margin="0,0,0,10">
                                        <Border Background="#EBF5FB" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                            <TextBlock FontSize="12" Foreground="#3498DB"><Run Text="👤 Волонтёр: "/><Run Text="{Binding Volunteername}" FontWeight="SemiBold"/></TextBlock>
                                        </Border>
                                        <Border Background="#FEF5E7" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                            <TextBlock FontSize="12" Foreground="#F39C12"><Run Text="📅 Срок: "/><Run Text="{Binding Duedate, StringFormat='dd.MM.yyyy'}" FontWeight="SemiBold"/></TextBlock>
                                        </Border>
                                        <Border Background="#E8F8F5" CornerRadius="6" Padding="8,4" Margin="0,0,8,0" Visibility="{Binding AnimalVisibility}">
                                            <TextBlock FontSize="12" Foreground="#1ABC9C"><Run Text="🐾 "/><Run Text="{Binding Animalname}" FontWeight="SemiBold"/></TextBlock>
                                        </Border>
                                        <Border Background="{Binding Statuscolor}" CornerRadius="6" Padding="10,6">
                                            <TextBlock Text="{Binding Status}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="20,0,0,0">
                                    <Button Content="✓ Выполнить" Tag="{Binding Taskid}" Click="BtnComplete_Click" Width="140" Height="36" Margin="0,0,0,8" Style="{StaticResource SuccessButton}" Visibility="{Binding CanCompleteVisibility}"/>
                                    <Button Content="✗ Отклонить" Tag="{Binding Taskid}" Click="BtnReject_Click" Width="140" Height="36" Margin="0,0,0,8" Style="{StaticResource DangerButton}" Visibility="{Binding CanRejectVisibility}"/>
                                    <Button Content="✏️ Изменить" Tag="{Binding Taskid}" Click="BtnEdit_Click" Width="140" Height="36" Margin="0,0,0,8" Style="{StaticResource PrimaryButton}"/>
                                    <Button Content="🗑 Удалить" Tag="{Binding Taskid}" Click="BtnDelete_Click" Width="140" Height="36" Style="{StaticResource DangerButton}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>