<Window x:Class="AnimalShelterAI.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь - Приют" Height="700" Width="850"
                Icon="C:\Users\alialialilalala\Pictures\Screenshots\shelter.png"

        WindowStartupLocation="CenterOwner" Background="#F8F9FA" ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="8" Opacity="0.12" Color="#000000"/>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="👤" FontSize="32" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock x:Name="txtWindowTitle" Text="Новый пользователь" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Заполните информацию о пользователе" FontSize="13" Foreground="#B0BEC5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="👤 Личная информация" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="#2C3E50"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Фамилия *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox x:Name="txtLastName" Height="42" Padding="12,10" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Имя *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox x:Name="txtFirstName" Height="42" Padding="12,10" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Отчество" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox x:Name="txtMiddleName" Height="42" Padding="12,10" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Email *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox x:Name="txtEmail" Height="42" Padding="12,10" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Телефон" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox x:Name="txtPhone" Height="42" Padding="12,10" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="🔐 Данные для входа" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="#2C3E50"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Логин *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBox x:Name="txtUsername" Height="42" Padding="12,10" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Пароль *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <PasswordBox x:Name="txtPassword" Height="42" Padding="12,10" FontSize="14"/>
                                <TextBlock Text="* Минимум 6 символов" FontSize="11" Foreground="#95A5A6" Margin="5,5,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Роль *" FontWeight="SemiBold" Margin="0,16,0,8"/>
                        <ComboBox x:Name="cmbRole" Height="42" FontSize="14" Padding="12,10">
                            <ComboBoxItem Content="Пользователь" Tag="User" IsSelected="True"/>
                            <ComboBoxItem Content="Волонтер" Tag="Volunteer"/>
                            <ComboBoxItem Content="Ветеринар" Tag="Veterinarian"/>
                            <ComboBoxItem Content="Менеджер" Tag="Manager"/>
                            <ComboBoxItem Content="Сотрудник" Tag="Employee"/>
                            <ComboBoxItem Content="Администратор" Tag="Administrator"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,10,0,0" BorderBrush="#E9ECEF" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="BtnCancel_Click" Width="130" Height="48" Margin="0,0,12,0"/>
                <Button x:Name="btnSave" Content="Сохранить пользователя" Click="BtnSave_Click" Width="210" Height="48" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>