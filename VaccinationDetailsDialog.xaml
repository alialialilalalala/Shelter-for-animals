<Window x:Class="AnimalShelterAI.VaccinationDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали вакцинации"
                Icon="C:\Users\alialialilalala\Pictures\Screenshots\shelter.png"

        Height="600" Width="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="3" Opacity="0.12" Color="#000000"/>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGradient}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryGradient}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💉" FontSize="32" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <StackPanel>
                    <TextBlock Text="Детали вакцинации" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="txtSubtitle" Text="Информация о прививке" FontSize="13" Foreground="#B0BEC5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="💉 Вакцинация" Style="{StaticResource InfoLabel}"/>
                <TextBlock x:Name="txtVaccineName" Style="{StaticResource InfoValue}"/>

                <TextBlock Text="🐾 Животное" Style="{StaticResource InfoLabel}"/>
                <TextBlock x:Name="txtAnimalName" Style="{StaticResource InfoValue}"/>

                <TextBlock Text="👨‍⚕️ Ветеринар" Style="{StaticResource InfoLabel}"/>
                <TextBlock x:Name="txtVetName" Style="{StaticResource InfoValue}"/>

                <TextBlock Text="📅 Дата вакцинации" Style="{StaticResource InfoLabel}"/>
                <TextBlock x:Name="txtVaccinationDate" Style="{StaticResource InfoValue}"/>

                <TextBlock Text="⏳ Дата следующей вакцинации" Style="{StaticResource InfoLabel}"/>
                <TextBlock x:Name="txtNextVaccinationDate" Style="{StaticResource InfoValue}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,20,0,0" BorderBrush="#E9ECEF" BorderThickness="1">
            <Button Content="Закрыть" Click="BtnClose_Click" Width="120" Height="40" HorizontalAlignment="Right" Style="{StaticResource PrimaryButton}"/>
        </Border>
    </Grid>
</Window>